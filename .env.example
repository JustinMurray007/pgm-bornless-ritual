# ElevenLabs API key — get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Supabase project URL — found in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key — found in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key — used only for the seed script (never expose client-side)
# Found in Supabase project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ElevenLabs voice ID for vox magica pronunciation (optional)
# Defaults to "EXAVITQu4vr4xnSDxMaL" (Aria — multilingual voice with Greek support)
# Override with any ElevenLabs voice ID from https://elevenlabs.io/app/voice-library
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
